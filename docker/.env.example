# ---------- MinIO Configuration ----------
# MinIO endpoint URL (e.g., http://localhost:9000 or http://minio:9000)
MINIO_ENDPOINT=
# MinIO access key (username)
MINIO_ACCESS_KEY=
# MinIO secret key (password)
MINIO_SECRET_KEY=
# MinIO bucket name for churn data storage
MINIO_BUCKET=
# Path for JSON file in MinIO (e.g., raw/bank_churn_data.json)
MINIO_FILE_PATH=
# Use SSL for MinIO connection (true/false)
MINIO_USE_SSL=

# ---------- Kafka Configuration ----------
# Kafka topic for churn events
KAFKA_TOPIC=
# Kafka bootstrap server address (e.g., localhost:9092 or host.docker.internal:29092)
KAFKA_BOOTSTRAP_SERVERS=
# Kafka consumer group ID
KAFKA_GROUP_ID=
# Kafka auto offset reset (earliest/latest)
KAFKA_AUTO_OFFSET_RESET=
# Kafka acknowledgments (all/0/1)
KAFKA_ACKS=
# Kafka retries count
KAFKA_RETRIES=

# ---------- Batch Settings ----------
# Number of records to process in each batch
BATCH_SIZE=
# Path to the bank churn CSV file
CSV_PATH=
# Request timeout for Kafka producer (milliseconds)
REQUEST_TIMEOUT_MS=

# ---------- Airflow User ID ----------
# Airflow user UID for container permissions
AIRFLOW_UID=

# ---------- GCP Configuration ----------
# Path to Google Cloud service account key file
GOOGLE_APPLICATION_CREDENTIALS=
# Google Cloud Project ID
GCP_PROJECT_ID=
# BigQuery dataset name
BQ_DATASET=
# BigQuery table name for raw churn data
BQ_TABLE=

# ---------- PostgreSQL Configuration ----------
# PostgreSQL username for Airflow metadata database
POSTGRES_USER=
# PostgreSQL password
POSTGRES_PASSWORD=
# PostgreSQL database name
POSTGRES_DB=

# ---------- Airflow Admin User ----------
# Airflow admin username
AIRFLOW_ADMIN_USER=
# Airflow admin first name
AIRFLOW_ADMIN_FIRSTNAME=
# Airflow admin last name
AIRFLOW_ADMIN_LASTNAME=
# Airflow admin email address
AIRFLOW_ADMIN_EMAIL=
# Airflow admin password
AIRFLOW_ADMIN_PASSWORD=

# ---------- Simulation Settings ----------
# Number of simulated users generating events
USER_COUNT=
# Interval in seconds between simulated events
EVENT_INTERVAL_SECONDS=